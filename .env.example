# Copy this file to `.env` and fill in the blank values below.
# `.env` is gitignored — never commit real credentials.

# Private Verdaccio registry auth token (see bunfig.toml / .npmrc scope
# mapping for @suaveplan). Required for installing/publishing @suaveplan/* packages.
NPM_TOKEN=

# SurrealDB connection — used by any package/app that persists to SurrealDB.
# Defaults shown assume a local instance; point at your own deployment.
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_ROOT_USER=root
SURREAL_ROOT_PASS=

# Verdaccio S3 (Garage) storage backend — required only for
# `bun scripts/publish/publish.ts --overwrite=<pkg>`. Endpoint/bucket/region
# defaults shown are for the shared SuavePlan registry; access keys are
# per-user credentials and must not be shared or committed.
S3_ENDPOINT=https://s3.fq.io
S3_BUCKET=npmjs
S3_REGION=uk
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Knowledge-base gateway connector — only needed if this project queries the
# shared SuavePlan knowledge base.
KB_CONNECTOR_KEY=
KB_CONNECTOR_URL=https://kb.fq.io
